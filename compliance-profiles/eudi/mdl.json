{
  "id": "cp-eudi-mdl",
  "name": "EUDI Wallet — Mobile Driver License",
  "compliance_code": "EUDI_MDL",
  "version": "1.0.0",
  "credential_format": "MDOC",
  "description": "Compliance profile for EUDI Wallet mobile Driver's License (mDL) credentials. Implements EU mDL Rule Book requirements using ISO 18013-5 mDoc format.",
  "specification_reference": "EUDI Wallet Architecture and Reference Framework (ARF) v1.4 — mDL Rule Book",
  "required_claims": [
    {"name": "family_name", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "given_name", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "birth_date", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "issue_date", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "expiry_date", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "issuing_country", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "issuing_authority", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "document_number", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "portrait", "namespace": "org.iso.18013.5.1", "required": true},
    {"name": "driving_privileges", "namespace": "org.iso.18013.5.1", "required": true}
  ],
  "supported_algorithms": ["ES256", "ES384"],
  "key_requirements": {
    "min_key_size_bits": 256,
    "key_modes": ["HSM", "SECURE_ELEMENT"],
    "key_algorithm_families": ["EC"]
  },
  "revocation_methods": ["OCSP", "CRL", "STATUS_LIST_2021"],
  "revocation_required": true,
  "allow_skip_revocation": false,
  "trust_source_types": ["TRUST_LIST", "ROOT_CA"],
  "holder_binding_required": true,
  "api_surface": [
    {
      "rel": "openid-credential-issuer-metadata",
      "path_template": "/.well-known/openid-credential-issuer",
      "org_scoped_path": "/org/{org_id}/.well-known/openid-credential-issuer",
      "method": "GET",
      "auth_required": false,
      "discoverable": true,
      "standard_ref": "OpenID for Verifiable Credential Issuance §11.2.3",
      "response_schema_ref": "https://raw.githubusercontent.com/marty-protocol/marty-protocol/main/schemas/oid4vci-issuer-metadata.json"
    },
    {
      "rel": "token",
      "path_template": "/v1/issuance/token",
      "org_scoped_path": "/org/{org_id}/v1/issuance/token",
      "method": "POST",
      "auth_required": false,
      "discoverable": true,
      "standard_ref": "RFC 6749 §3.2 / OID4VCI §6"
    },
    {
      "rel": "credential",
      "path_template": "/v1/issuance/credential",
      "org_scoped_path": "/org/{org_id}/v1/issuance/credential",
      "method": "POST",
      "auth_required": true,
      "discoverable": true,
      "standard_ref": "OpenID for Verifiable Credential Issuance §7"
    },
    {
      "rel": "nonce",
      "path_template": "/v1/issuance/nonce",
      "org_scoped_path": "/org/{org_id}/v1/issuance/nonce",
      "method": "POST",
      "auth_required": false,
      "discoverable": true,
      "standard_ref": "OpenID for Verifiable Credential Issuance §8"
    },
    {
      "rel": "deferred-credential",
      "path_template": "/v1/issuance/deferred-credential",
      "org_scoped_path": "/org/{org_id}/v1/issuance/deferred-credential",
      "method": "POST",
      "auth_required": true,
      "discoverable": true,
      "standard_ref": "OpenID for Verifiable Credential Issuance §9"
    },
    {
      "rel": "notification",
      "path_template": "/v1/issuance/notification",
      "org_scoped_path": "/org/{org_id}/v1/issuance/notification",
      "method": "POST",
      "auth_required": true,
      "discoverable": true,
      "standard_ref": "OpenID for Verifiable Credential Issuance §10 / EUDI ARF v1.4"
    },
    {
      "rel": "status-list",
      "path_template": "/v1/issuance/status-list",
      "org_scoped_path": "/org/{org_id}/v1/issuance/status-list",
      "method": "GET",
      "auth_required": false,
      "discoverable": true,
      "standard_ref": "IETF Token Status List draft-ietf-oauth-status-list / EUDI ARF v1.4"
    },
    {
      "rel": "device-engagement",
      "path_template": "/v1/issuance/device-engagement",
      "org_scoped_path": "/org/{org_id}/v1/issuance/device-engagement",
      "method": "GET",
      "auth_required": false,
      "discoverable": false,
      "standard_ref": "ISO/IEC 18013-5:2021 §8.2.1 — Device Engagement (QR code or NFC)"
    },
    {
      "rel": "session-establishment",
      "path_template": "/v1/issuance/sessions",
      "org_scoped_path": "/org/{org_id}/v1/issuance/sessions",
      "method": "POST",
      "auth_required": false,
      "discoverable": false,
      "standard_ref": "ISO/IEC 18013-5:2021 §8.3 — Session Establishment"
    }
  ],
  "is_system": true,
  "immutable": true,
  "status": "ACTIVE",
  "created_at": "2026-01-01T00:00:00Z"
}
