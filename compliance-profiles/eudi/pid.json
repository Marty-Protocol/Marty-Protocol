{
  "id": "cp-eudi-pid",
  "name": "EUDI Wallet — Person Identification Data",
  "compliance_code": "EUDI_PID",
  "version": "1.0.0",
  "credential_format": "SD_JWT_VC",
  "description": "Compliance profile for EUDI Wallet Person Identification Data (PID) credentials. Implements the EUDI ARF PID Rule Book requirements using SD-JWT-VC format.",
  "specification_reference": "EUDI Wallet Architecture and Reference Framework (ARF) v1.4 — PID Rule Book",
  "required_claims": [
    {"name": "family_name", "required": true},
    {"name": "given_name", "required": true},
    {"name": "birth_date", "required": true},
    {"name": "issuing_country", "required": true},
    {"name": "issuing_authority", "required": true}
  ],
  "optional_claims": [
    {"name": "age_over_18", "required": false},
    {"name": "age_over_21", "required": false},
    {"name": "age_in_years", "required": false},
    {"name": "place_of_birth", "required": false},
    {"name": "address", "required": false},
    {"name": "gender", "required": false},
    {"name": "nationality", "required": false}
  ],
  "supported_algorithms": ["ES256", "ES384", "PS256", "PS384"],
  "key_requirements": {
    "min_key_size_bits": 256,
    "key_modes": ["HSM", "SECURE_ELEMENT"],
    "key_algorithm_families": ["EC", "RSA"]
  },
  "revocation_methods": ["STATUS_LIST_2021", "BITSTRING_STATUS_LIST", "TOKEN_STATUS_LIST"],
  "revocation_required": true,
  "allow_skip_revocation": false,
  "trust_source_types": ["TRUST_LIST", "ROOT_CA"],
  "holder_binding_required": true,
  "selective_disclosure_required": true,
  "is_system": true,
  "immutable": true,
  "status": "ACTIVE",
  "discoverable": true,
  "api_surface": [
    {
      "rel": "openid-credential-issuer",
      "path_template": "/.well-known/openid-credential-issuer",
      "org_scoped_path": "/org/{org_id}/.well-known/openid-credential-issuer",
      "method": "GET",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a711.2.2"
    },
    {
      "rel": "oauth-authorization-server",
      "path_template": "/.well-known/oauth-authorization-server",
      "org_scoped_path": "/org/{org_id}/.well-known/oauth-authorization-server",
      "method": "GET",
      "auth_required": false,
      "standard_ref": "RFC 8414 / EUDI ARF \u00a77.1"
    },
    {
      "rel": "oid4vci-credential-offer",
      "path_template": "/v1/issuance/offers/{tx_id}",
      "method": "GET",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a75.1"
    },
    {
      "rel": "oid4vci-token",
      "path_template": "/v1/issuance/token",
      "method": "POST",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a76.1"
    },
    {
      "rel": "oid4vci-credential",
      "path_template": "/v1/issuance/credential",
      "method": "POST",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a78"
    },
    {
      "rel": "oid4vci-nonce",
      "path_template": "/v1/issuance/nonce",
      "method": "POST",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a78.3"
    },
    {
      "rel": "oid4vci-deferred-credential",
      "path_template": "/v1/issuance/deferred-credential",
      "method": "POST",
      "auth_required": false,
      "standard_ref": "OID4VCI \u00a79"
    }
  ],
  "created_at": "2026-01-01T00:00:00Z"
}
