{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/did-report/marty-protocol/main/schemas/device-registration.json",
  "title": "DeviceRegistration",
  "description": "User device record for push notification delivery and challenge-response authentication",
  "type": "object",
  "required": ["user_id", "device_id", "platform", "fcm_token", "is_active", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "user_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "organization_id": {"type": ["string", "null"], "format": "uuid"},
    "device_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "platform": {
      "type": "string",
      "enum": ["ios", "android", "web"]
    },
    "fcm_token": {"type": "string", "minLength": 1},
    "app_version": {"type": "string"},
    "os_version": {"type": "string"},
    "device_model": {"type": "string"},
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "credential_notifications": {"type": "boolean", "default": true},
        "verification_notifications": {"type": "boolean", "default": true},
        "system_notifications": {"type": "boolean", "default": true},
        "quiet_hours_start": {"type": ["string", "null"], "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"},
        "quiet_hours_end": {"type": ["string", "null"], "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"}
      }
    },
    "public_key_der": {
      "type": "string",
      "contentEncoding": "base64url",
      "description": "Base64url-encoded RSA public key in PKCS#1 DER format"
    },
    "public_key_kid": {
      "type": "string",
      "description": "SHA-256 thumbprint of the public key per RFC 7638"
    },
    "key_valid_from": {"type": "string", "format": "date-time"},
    "key_valid_until": {"type": "string", "format": "date-time"},
    "is_active": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "last_seen_at": {"type": "string", "format": "date-time"}
  },
  "if": {
    "required": ["public_key_der"]
  },
  "then": {
    "required": ["public_key_kid"]
  }
}
