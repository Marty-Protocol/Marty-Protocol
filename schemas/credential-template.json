{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/marty-protocol/marty-protocol/main/schemas/credential-template.json",
  "title": "CredentialTemplate",
  "description": "Master issuance configuration combining schema, compliance profile, and cryptographic materials",
  "type": "object",
  "required": ["id", "organization_id", "name", "credential_type", "compliance_profile_id", "claims", "validity_rules", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "organization_id": {"type": "string", "format": "uuid"},
    "name": {"type": "string", "minLength": 1, "maxLength": 128},
    "credential_type": {
      "type": "string",
      "pattern": "^[A-Z][a-zA-Z0-9]+$",
      "description": "PascalCase semantic type identifier"
    },
    "description": {"type": "string", "maxLength": 1024},
    "compliance_profile_id": {"type": "string", "format": "uuid"},
    "vct": {
      "type": ["string", "null"],
      "maxLength": 512,
      "description": "Verifiable Credential Type string. REQUIRED when the governing compliance profile specifies credential_format = SD_JWT_VC. MUST be a URI or a collision-resistant string. Per IETF SD-JWT-VC §3.2.2."
    },
    "credential_payload_format": {
      "type": "string",
      "enum": ["SD_JWT_VC", "MDOC", "VC_JWT", "JSON_LD"],
      "description": "Explicit payload encoding format. If set, MUST be consistent with the credential_format of the referenced compliance profile; may not be overridden to a different format family."
    },
    "application_template_id": {"type": ["string", "null"], "format": "uuid"},
    "trust_profile_id": {"type": ["string", "null"], "format": "uuid"},
    "revocation_profile_id": {"type": ["string", "null"], "format": "uuid"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "required"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "type": {"type": "string", "enum": ["STRING", "INTEGER", "BOOLEAN", "DATE", "OBJECT", "ARRAY"]},
          "description": {"type": "string"},
          "required": {"type": "boolean"},
          "selectively_disclosable": {"type": "boolean", "default": false},
          "derived_from": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "namespace": {"type": "string"},
          "display": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "icon": {"type": "string"}
            }
          }
        }
      }
    },
    "validity_rules": {
      "type": "object",
      "required": ["ttl_seconds"],
      "additionalProperties": false,
      "properties": {
        "ttl_seconds": {"type": "integer", "minimum": 1},
        "renewable": {"type": "boolean", "default": false},
        "reissue_within_seconds": {"type": "integer", "minimum": 1},
        "not_before_offset_seconds": {"type": "integer", "minimum": 0}
      }
    },
    "issuer_key_id": {"type": "string"},
    "issuer_algorithm": {"type": "string"},
    "key_access_mode": {"type": "string", "enum": ["KEY_VAULT", "HSM", "LOCAL"]},
    "issuer_certificate_chain_pem": {"type": "string"},
    "issuer_did": {"type": "string", "pattern": "^did:"},
    "auto_generate_artifacts": {"type": "boolean", "default": false},
    "privacy_posture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_disclose_all": {"type": "boolean", "default": true},
        "prefer_predicates": {"type": "boolean", "default": false},
        "sd_alg": {"type": "string", "default": "sha-256"}
      }
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "ACTIVE", "DEPRECATED"]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "$comment": "vct is required when compliance profile format is SD_JWT_VC. Since we cannot resolve the compliance_profile_id dynamically in JSON Schema, implementations MUST enforce this rule at the application layer.",
      "if": {
        "properties": {
          "credential_payload_format": {"const": "SD_JWT_VC"}
        },
        "required": ["credential_payload_format"]
      },
      "then": {
        "required": ["vct"],
        "properties": {
          "vct": {"type": "string"}
        }
      }
    },
    {
      "$comment": "Inline compliance profiles are forbidden. A Credential Template MUST reference a Compliance Profile by compliance_profile_id (UUID). Embedding a compliance profile object in the template body is not permitted.",
      "not": {
        "required": ["compliance_profile"],
        "properties": {
          "compliance_profile": {"type": "object"}
        }
      }
    }
  ]
}
