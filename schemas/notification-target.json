{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/did-report/marty-protocol/main/schemas/notification-target.json",
  "title": "NotificationTarget",
  "description": "Multi-channel message delivery targeting configuration",
  "type": "object",
  "required": ["channels"],
  "additionalProperties": false,
  "properties": {
    "organization_id": {"type": "string", "format": "uuid"},
    "user_id": {"type": "string"},
    "device_tokens": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "webhook_endpoints": {
      "type": "array",
      "items": {"type": "string", "format": "uri", "pattern": "^https://"},
      "uniqueItems": true
    },
    "email_addresses": {
      "type": "array",
      "items": {"type": "string", "format": "email"},
      "uniqueItems": true
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["FCM", "SSE", "WEBHOOK", "EMAIL", "SMS"]
      }
    }
  },
  "anyOf": [
    {"required": ["organization_id"]},
    {"required": ["user_id"]},
    {"required": ["device_tokens"], "properties": {"device_tokens": {"minItems": 1}}},
    {"required": ["webhook_endpoints"], "properties": {"webhook_endpoints": {"minItems": 1}}},
    {"required": ["email_addresses"], "properties": {"email_addresses": {"minItems": 1}}}
  ]
}
